# https://unix.stackexchange.com/a/176331
function setenv() { export "$1=$2"; }
[ -f ~/.env ] && . ~/.env
[ -f ~/.profile-local ] && . ~/.profile-local

[ -d ~/.cache/nvim ] || export NVIM_APPNAME=nvim-lite

# FreeBSD has /home linked to /usr/home, this leads to a prompt showing
# /usr/home/user instead of ~
if [ "$PWD" != "$HOME" ] && [ "$PWD" -ef "$HOME" ] ; then cd ; fi
